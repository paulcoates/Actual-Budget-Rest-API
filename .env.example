# Required Environment Variables
BUDGET_ID=your-budget-sync-id-here
SERVER_URL=https://your-actual-server.com
SERVER_PASSWORD=your-server-password

# Optional Environment Variables
PORT=8080
NODE_ENV=production

# UpBank Integration (Optional)
UPBANK_TOKEN=your-upbank-api-token
UPBANK_WEBHOOK_SECRET=your-upbank-webhook-secret
DEFAULT_ACCOUNT_ID=your-default-actual-account-id
# Set to "false" to disable signature verification (NOT recommended for production)
# UPBANK_VERIFY_WEBHOOK_SIGNATURE=true
# Set to "true" to log request bodies and other sensitive data (NOT recommended for production)
# LOG_SENSITIVE_DATA=false
# Optional JSON map of UpBank account ID to Actual account ID
# Example: {"up-account-id":"actual-account-id"}
# UPBANK_ACCOUNT_MAP={}

# Development/Testing
# NODE_ENV=development
# NODE_ENV=test
